{
  "name": "chat-codex",
  "version": "0.1.4",
  "description": "Connect local Codex to Weixin and Feishu through a terminal TUI.",
  "author": "小黄 and Codex",
  "license": "MIT",
  "type": "module",
  "homepage": "https://github.com/uluckyXH/Chat-Codex#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/uluckyXH/Chat-Codex.git"
  },
  "bugs": {
    "url": "https://github.com/uluckyXH/Chat-Codex/issues"
  },
  "keywords": [
    "codex",
    "chat",
    "wechat",
    "weixin",
    "feishu",
    "lark",
    "tui",
    "ink"
  ],
  "files": [
    "dist/src/**/*.js",
    "README.md",
    "README.en.md",
    "README.zh-CN.md",
    "LICENSE",
    "npm-shrinkwrap.json"
  ],
  "bundleDependencies": [
    "@larksuiteoapi/node-sdk"
  ],
  "bin": {
    "chat-codex": "dist/src/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && node --test dist/tests/unit/*.test.js dist/tests/integration/*.test.js",
    "test:unit": "npm run build && node --test dist/tests/unit/*.test.js",
    "test:integration": "npm run build && node --test dist/tests/integration/*.test.js",
    "chat-codex": "npm run build && node dist/src/cli.js",
    "cli:chat-codex": "npm run build && node dist/src/cli.js",
    "cli:mock": "npm run build && node dist/src/cli.js test",
    "cli:terminal:mock": "npm run build && node dist/src/cli.js terminal mock",
    "cli:terminal:codex": "npm run build && node dist/src/cli.js terminal codex",
    "cli:weixin:status": "npm run build && node dist/src/cli.js weixin status",
    "cli:weixin:login": "npm run build && node dist/src/cli.js weixin login",
    "cli:feishu:status": "npm run build && node dist/src/cli.js feishu status",
    "pack:dry-run": "npm pack --dry-run",
    "prepack": "npm run build && node scripts/patch-bundled-lark-sdk.mjs",
    "prepublishOnly": "npm test"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@types/node": "^24.10.0",
    "@types/react": "^19.2.14",
    "ink-testing-library": "^4.0.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@inkjs/ui": "^2.0.0",
    "@larksuiteoapi/node-sdk": "^1.64.0",
    "ink": "^7.0.3",
    "qrcode-terminal": "^0.12.0",
    "react": "^19.2.6"
  },
  "overrides": {
    "axios": "^1.16.1"
  }
}
